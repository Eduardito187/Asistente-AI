# ============================================================
# Variables de entorno para despliegue cloud
# Copiar a .env y completar con valores reales.
# NUNCA commitear este archivo con valores reales.
# ============================================================

# ------------------------------------------------------------
# BASE DE DATOS — Opciones cloud (elegir una)
# ------------------------------------------------------------
# Opcion A: PlanetScale (MySQL compatible, serverless, free tier)
DATABASE_URL=mysql+pymysql://usuario:password@host.planetscale.com:3306/asistente_db?ssl_ca=/etc/ssl/certs/ca-certificates.crt&charset=utf8mb4

# Opcion B: AWS RDS MariaDB
# DATABASE_URL=mysql+pymysql://usuario:password@endpoint.rds.amazonaws.com:3306/asistente_db?charset=utf8mb4

# Opcion C: Google Cloud SQL (via Cloud SQL Proxy)
# DATABASE_URL=mysql+pymysql://usuario:password@127.0.0.1:3306/asistente_db?charset=utf8mb4

# Opcion D: Supabase (Postgres — requiere cambiar PyMySQL por psycopg2 y ajustar SQL)
# DATABASE_URL=postgresql://usuario:password@db.supabase.co:5432/postgres

# Variables sueltas (alternativa a DATABASE_URL — env.py las une)
DB_HOST=host.planetscale.com
DB_PORT=3306
DB_USER=usuario
DB_PASS=password
DB_NAME=asistente_db

# ------------------------------------------------------------
# CACHE REDIS — Opciones cloud
# ------------------------------------------------------------
# Opcion A: Upstash (serverless, free tier 10k cmd/dia)
REDIS_URL=rediss://default:password@host.upstash.io:6380/0

# Opcion B: AWS ElastiCache
# REDIS_URL=redis://endpoint.cache.amazonaws.com:6379/0

# Opcion C: Redis Cloud
# REDIS_URL=redis://default:password@host.redis.cloud:12345/0

# ------------------------------------------------------------
# LLM — Opciones cloud (elegir una estrategia)
# ------------------------------------------------------------

# --- Estrategia A: Groq API (recomendada — Qwen 2.5 disponible gratis) ---
# Compatible con la interfaz OpenAI. Cambiar OllamaAdapter por GroqAdapter.
# Latencia: ~200-400ms por respuesta. Sin GPU propia.
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_xxxx
GROQ_MODEL=qwen-2.5-7b-instruct          # o llama-3.3-70b, mixtral-8x7b

# --- Estrategia B: Anthropic API (claude-haiku-4-5) ---
# Mejor razonamiento, mas caro. ~$0.00025 input / $0.00125 output por 1K tokens.
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-xxxx
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Estrategia C: Ollama en servidor propio (RTX 5090 local con tunel) ---
# Exponés tu servidor local con un tunel seguro (ngrok, Cloudflare Tunnel).
# Requiere el servidor local encendido. Latencia ~100ms + latencia tunel.
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=https://tu-tunnel.ngrok.io
# OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M

# --- Estrategia D: GPU cloud bajo demanda (cara pero autónoma) ---
# AWS p3.2xlarge (~$3/hr), Lambda Labs A10 (~$0.60/hr), RunPod.
# Instalar Ollama en la instancia GPU y apuntar OLLAMA_BASE_URL.
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://gpu-instance-ip:11434
# OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M

# ------------------------------------------------------------
# APP CONFIG
# ------------------------------------------------------------
APP_SECRET_KEY=cambia_esto_por_un_secret_largo_y_aleatorio
DEBUG=false
LOG_LEVEL=INFO

# Puerto en el que escucha el backend
PORT=8000

# ------------------------------------------------------------
# FRONTEND — Variables para build
# ------------------------------------------------------------
# URL pública del backend (usada por nginx como proxy_pass)
BACKEND_URL=https://api.tu-dominio.com

# ------------------------------------------------------------
# OPCIONAL: Monitoreo y observabilidad
# ------------------------------------------------------------
# Sentry (errores y performance)
# SENTRY_DSN=https://key@sentry.io/project-id

# OpenTelemetry (traces distribuidos)
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.tu-plataforma.com
