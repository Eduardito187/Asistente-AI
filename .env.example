# ============================================================
# Asistente AI Dismac - Variables de entorno
# Copiar a .env y ajustar
# ============================================================

# ---------- Ollama ----------
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_HOST=http://ollama:11434

# ---------- MariaDB (BD propia del asistente) ----------
MARIADB_ROOT_PASSWORD=asistente_root
MARIADB_USER=asistente
MARIADB_PASSWORD=asistente_pass
MARIADB_DB=asistente_db
MARIADB_HOST=db
MARIADB_PORT=3306

# ---------- MySQL origen ----------
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_USER=dismac
MYSQL_PASSWORD=dismac_pass
MYSQL_DB=dismac_erp
MYSQL_HOST=mysql-source
MYSQL_PORT=3306

# ---------- Ingestor ----------
INGEST_SOURCE=dismac_csv
INGEST_INTERVAL_SECONDS=86400
INGEST_REST_URL=http://mock-api:8080/productos
INGEST_GRAPHQL_URL=http://mock-api:8080/graphql
INGEST_CSV_PATH=/app/data/samples/productos_sample.csv
INGEST_DISMAC_CSV_PATH=/app/data/feed_meta_scz.csv

# ---------- Backend ----------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
APP_LOCALE=es_BO
APP_CURRENCY=BOB

# ---------- Frontend ----------
FRONTEND_PORT=8501
BACKEND_URL=http://backend:8000
